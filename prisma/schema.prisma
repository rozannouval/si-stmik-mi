generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MAHASISWA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  DOSEN
  MAHASISWA
}

enum DegreeType {
  D3
  D4
  S1
  S2
}

model ProgramStudi {
  id        String   @id @default(cuid())
  kode      String   @unique
  nama      String
  jenjang   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("program_studi")
}